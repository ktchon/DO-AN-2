rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if true;  // Cho phép tất cả (test local/emulator only!)
      // Hoặc an toàn hơn nếu bạn sign in user trước upload:
      // allow read, write: if request.auth != null;
    }
  }
}